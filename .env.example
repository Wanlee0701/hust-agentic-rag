# ── Google Gemini (bắt buộc khi provider='gemini' trong config.yaml) ──
# Lấy API Key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── LangSmith Observability (tuỳ chọn) ──────────────────────────────
# Đăng ký miễn phí tại: https://smith.langchain.com
# Khi bật, toàn bộ LangGraph traces sẽ được ghi lại trên dashboard
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=hust-agentic-rag

# ── Ollama (tuỳ chọn — chỉ dùng khi provider='ollama') ─────────────
